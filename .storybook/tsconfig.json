{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "baseUrl": "../",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "skipLibCheck": true
  },
  "exclude": [
    "../src/**/*.spec.ts"
  ],
  "include": [
    "../src/**/*.stories.ts",
    "../src/**/*.component.ts",
    "./preview.ts",
    "./main.ts"
  ]
}